{
  "name": "fly-dev",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:client\" \"npm:dev:worker\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:worker": "WRANGLER_LOG_PATH=.wrangler/logs/wrangler.log WRANGLER_REGISTRY_PATH=.wrangler/registry wrangler --cwd worker dev -c ../wrangler.jsonc --port 8787 --ip 127.0.0.1",
    "build": "vite build && tsc -p worker/tsconfig.json --noEmit",
    "cf:dry-run": "wrangler deploy --dry-run",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv worker-configuration.d.ts",
    "migrate:local": "wrangler d1 migrations apply fly-dev --local",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p worker/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.4",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.120.0",
    "agents": "^0.13.2",
    "better-auth": "^1.5.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.2026.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.0",
    "playwright-core": "^1.60.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.0.0"
  }
}
